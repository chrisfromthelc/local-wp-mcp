{
  "name": "@chrisfromthelc/local-wp-mcp",
  "version": "1.0.0",
  "description": "MCP server providing WP-CLI, MySQL, and filesystem access for Local by Flywheel WordPress sites",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "local-wp-mcp": "dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/chrisfromthelc/local-wp-mcp.git"
  },
  "homepage": "https://github.com/chrisfromthelc/local-wp-mcp#readme",
  "bugs": {
    "url": "https://github.com/chrisfromthelc/local-wp-mcp/issues"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "wordpress",
    "wp-cli",
    "local-by-flywheel",
    "model-context-protocol",
    "claude",
    "ai"
  ],
  "author": "chrisfromthelc",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.11.0",
    "mysql2": "^3.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist"
  ]
}
